<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ModelViewer3D" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bg_surface</item>
        <item name="colorPrimaryVariant">@color/bg_medium</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_deepest</item>
        <item name="android:navigationBarColor">@color/bg_deepest</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="bottomSheetDialogTheme">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="bottomSheetStyle">@style/BottomSheetShapeStyle</item>
    </style>

    <style name="BottomSheetShapeStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <!-- Toolbar icon button -->
    <style name="ToolbarBtn">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:padding">10dp</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:tint">@color/text_secondary</item>
    </style>

    <!-- Accent toolbar button -->
    <style name="ToolbarBtnAccent">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:padding">10dp</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:tint">@color/accent_cyan</item>
    </style>
</resources>
