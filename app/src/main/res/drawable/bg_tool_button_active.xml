<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/tool_active_bg"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="@color/tool_active_stroke"/>
        </shape>
    </item>
    <item android:top="0dp" android:left="14dp" android:right="14dp" android:height="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_cyan"/>
            <corners android:radius="2dp"/>
        </shape>
    </item>
</layer-list>
