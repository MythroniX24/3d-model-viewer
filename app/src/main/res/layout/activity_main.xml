<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050508">

    <!-- ══ Full-screen GL Surface ══════════════════════════════════════════ -->
    <com.modelviewer3d.ModelGLSurfaceView
        android:id="@+id/glSurface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- ══ TOP TOOLBAR ═════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="4dp"
        android:background="@drawable/bg_toolbar"
        android:elevation="8dp">

        <!-- Logo -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingEnd="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3D"
                android:textColor="#00D4FF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:lineSpacingExtra="-2dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STUDIO"
                android:textColor="#30FFFFFF"
                android:textSize="7sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="28dp"
            android:background="#18FFFFFF" android:layout_marginEnd="2dp"/>

        <!-- Open -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent"
            android:orientation="vertical" android:gravity="center"
            android:paddingStart="2dp" android:paddingEnd="2dp"
            android:id="@+id/btnOpen" android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_folder" android:tint="#00D4FF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Open" android:textColor="#4400D4FF" android:textSize="8sp" android:paddingTop="1dp"/>
        </LinearLayout>

        <!-- Edit -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent"
            android:orientation="vertical" android:gravity="center"
            android:paddingStart="2dp" android:paddingEnd="2dp"
            android:id="@+id/btnEdit" android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_tune" android:tint="#BBBBCC"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Edit" android:textColor="#44BBBBCC" android:textSize="8sp" android:paddingTop="1dp"/>
        </LinearLayout>

        <!-- Meshes -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent"
            android:orientation="vertical" android:gravity="center"
            android:paddingStart="2dp" android:paddingEnd="2dp"
            android:id="@+id/btnMeshList" android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_layers" android:tint="#BBBBCC"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Meshes" android:textColor="#44BBBBCC" android:textSize="8sp" android:paddingTop="1dp"/>
        </LinearLayout>

        <!-- Ruler -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent"
            android:orientation="vertical" android:gravity="center"
            android:paddingStart="2dp" android:paddingEnd="2dp"
            android:id="@+id/btnRuler" android:clickable="true" android:focusable="true"
            android:alpha="0.45"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_ruler" android:tint="#BBBBCC"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Ruler" android:textColor="#44BBBBCC" android:textSize="8sp" android:paddingTop="1dp"/>
        </LinearLayout>

        <!-- Export -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent"
            android:orientation="vertical" android:gravity="center"
            android:paddingStart="2dp" android:paddingEnd="2dp"
            android:id="@+id/btnExport" android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_export" android:tint="#BBBBCC"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Export" android:textColor="#44BBBBCC" android:textSize="8sp" android:paddingTop="1dp"/>
        </LinearLayout>

        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <!-- Right group: secondary actions -->
        <ImageButton android:id="@+id/btnUndo"
            style="@style/ToolbarBtn" android:src="@drawable/ic_undo"
            android:contentDescription="Undo"/>
        <ImageButton android:id="@+id/btnRedo"
            style="@style/ToolbarBtn" android:src="@drawable/ic_redo"
            android:contentDescription="Redo"/>
        <ImageButton android:id="@+id/btnScreenshot"
            style="@style/ToolbarBtn" android:src="@drawable/ic_screenshot"
            android:contentDescription="Screenshot"/>
        <ImageButton android:id="@+id/btnReset"
            style="@style/ToolbarBtn" android:src="@drawable/ic_reset"
            android:contentDescription="Reset Camera"/>

        <!-- FPS -->
        <TextView
            android:id="@+id/tvFps"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#2800D4FF"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:gravity="center"/>
    </LinearLayout>

    <!-- ══ CENTER HINT (shown when no model loaded) ═════════════════════════ -->
    <LinearLayout
        android:id="@+id/tvHint"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="@drawable/bg_hint_card">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📦"
            android:textSize="52sp"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3D Studio"
            android:textColor="#F0F0FF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="10dp"
            android:fontFamily="monospace"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Open a 3D model to begin"
            android:textColor="#606080"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingTop="4dp"/>

        <!-- Format pills -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="OBJ" android:textColor="#00D4FF"
                android:background="@drawable/bg_pill" android:textSize="10sp"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:paddingTop="5dp" android:paddingBottom="5dp"
                android:layout_marginEnd="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="STL" android:textColor="#00D4FF"
                android:background="@drawable/bg_pill" android:textSize="10sp"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:paddingTop="5dp" android:paddingBottom="5dp"
                android:layout_marginEnd="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="GLB" android:textColor="#00D4FF"
                android:background="@drawable/bg_pill" android:textSize="10sp"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:paddingTop="5dp" android:paddingBottom="5dp"/>
        </LinearLayout>

        <!-- Gesture hints -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="18dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="1 finger  →  rotate" android:textColor="#383858"
                android:textSize="10sp" android:paddingBottom="2dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="2 fingers →  zoom / pan" android:textColor="#383858"
                android:textSize="10sp" android:paddingBottom="2dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="double-tap →  reset" android:textColor="#383858"
                android:textSize="10sp"/>
        </LinearLayout>

        <Button
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Open Model"
            android:textColor="#00D4FF"
            android:textSize="13sp"
            android:background="@drawable/bg_btn_accent"
            android:layout_marginTop="20dp"
            android:id="@+id/btnOpenHint"/>
    </LinearLayout>

    <!-- ══ STATUS BAR (bottom) ══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:background="@drawable/bg_status_bar"
        android:elevation="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvStatusMeshes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● 1 mesh"
            android:textColor="#00D4FF"
            android:textSize="10sp"
            android:fontFamily="monospace"/>

        <View android:layout_width="1dp" android:layout_height="12dp"
            android:background="#25FFFFFF"
            android:layout_marginStart="10dp" android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/tvStatusVerts"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 verts"
            android:textColor="#505070"
            android:textSize="10sp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tvStatusFile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#383858"
            android:textSize="10sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:maxWidth="140dp"/>
    </LinearLayout>

    <!-- ══ RULER OVERLAY ════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/rulerOverlay"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="34dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:background="#EE080E1C"
        android:visibility="gone"
        android:elevation="7dp">

        <TextView android:text="📐" android:textSize="16sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:paddingEnd="10dp"/>

        <TextView
            android:id="@+id/tvRulerInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tap mesh surface — Point 1"
            android:textColor="#F0F0FF"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/btnClearRuler"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Clear"
            android:textSize="10sp"
            android:textColor="#00D4FF"
            android:background="@drawable/bg_btn_accent"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"/>
    </LinearLayout>

    <!-- ══ LOADING OVERLAY ══════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D0050508"
        android:visibility="gone"
        android:elevation="12dp">

        <LinearLayout
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_hint_card"
            android:padding="32dp">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminate="true"
                android:indeterminateTint="#00D4FF"/>

            <TextView
                android:id="@+id/tvLoading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading…"
                android:textColor="#F0F0FF"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingTop="14dp"/>

            <TextView
                android:id="@+id/tvLoadingDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#404060"
                android:textSize="10sp"
                android:gravity="center"
                android:paddingTop="4dp"/>
        </LinearLayout>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
